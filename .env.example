# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://pharmacore_user:pharmacore_pass@localhost:5432/pharmacore_db
DATABASE_ECHO=True

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Application
APP_NAME=PharmaCore ERP
APP_VERSION=0.1.0
